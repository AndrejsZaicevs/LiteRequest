{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "LiteRequest default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "window-state:allow-filename",
    "window-state:allow-restore-state",
    "window-state:allow-save-window-state"
  ]
}
